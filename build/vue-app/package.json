{
  "name": "jetcpp-website",
  "version": "1.0.0",
  "description": "JetCPP Website",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --bun vite",
    "prebuild": "bun scripts/clean-public.js",
    "build": "bun run generate-rss && bun run --bun vite build && bun run deploy",
    "deploy": "bun scripts/deploy.js && bun -e \"import fs from 'fs'; fs.copyFileSync('dist/index.html', 'dist/404.html')\"",
    "preview": "bun run --bun vite preview",
    "generate-rss": "bun scripts/generate-rss.js",
    "add-project": "bun scripts/add-content.js project",
    "add-blog": "bun scripts/add-content.js blog"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/vue": "^4.3.0",
    "@supabase/supabase-js": "^2.105.1",
    "bootstrap": "^5.3.8",
    "markdown-it": "^14.1.1",
    "vue": "^3.2.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "esbuild": "^0.28.0",
    "prettier": "^3.9.4",
    "vite": "^8.0.10",
    "tsx": "^4"
  }
}
